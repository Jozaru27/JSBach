#!/bin/bash

# JSBach Router - DHCP Backend Logic
source /usr/local/JSBach/conf/variables.conf

COMANDO=$1

# Helper: IP string to integer
ip2int() {
    local IFS=.
    local ip=($1)
    echo "$(( (ip[0] << 24) | (ip[1] << 16) | (ip[2] << 8) | ip[3] ))"
}

# Helper: Check if two IPs are in same subnet
is_same_subnet() {
    local ip1=$(ip2int "$1")
    local ip2=$(ip2int "$2")
    local mask_str="$3"
    
    # Simple mask logic (assuming /24 for now if not valid int, or handle common ones)
    local mask=32
    if [[ "$mask_str" =~ ^[0-9]+$ ]]; then
        mask="$mask_str"
    elif [[ "$mask_str" == "255.255.255.0" ]]; then
        mask=24
    elif [[ "$mask_str" == "255.255.255.128" ]]; then
        mask=25
    elif [[ "$mask_str" == "255.255.0.0" ]]; then
        mask=16
    fi
    
    local shift=$(( 32 - mask ))
    [ "$(( ip1 >> shift ))" -eq "$(( ip2 >> shift ))" ]
}

case "$COMANDO" in
    iniciar)
        systemctl start dnsmasq > /dev/null 2>&1
        if [ $? -eq 0 ]; then echo "ACTIVAT"; else echo "DESACTIVAT"; fi
        echo "<h3>Resultat de l'operació</h3>"
        echo "<p>S'ha intentat iniciar el servei dnsmasq.</p>"
        ;;
    aturar)
        systemctl stop dnsmasq > /dev/null 2>&1
        echo "DESACTIVAT"
        echo "<h3>Resultat de l'operació</h3>"
        echo "<p>S'ha aturat el servei dnsmasq.</p>"
        ;;
    estat)
        if systemctl is-active --quiet dnsmasq; then
            echo "ACTIVAT"
        else
            echo "DESACTIVAT"
        fi
        
        echo "<h3>Estat del Servei DNSMasq</h3>"
        echo "<div style='font-family: monospace;'>"
        systemctl status dnsmasq | head -n 15
        echo "</div>"
        
        echo "<h3>Clientes DHCP Actius</h3>"
        echo "<div style='font-family: monospace;'>"
        if [ -f /var/lib/misc/dnsmasq.leases ]; then
            # Anonymize help: if 4th field is "*", replace with "Invitado Anónimo X"
            anon_count=1
            while read -r line; do
                hostname=$(echo "$line" | cut -d' ' -f4)
                if [ "$hostname" == "*" ]; then
                    new_line=$(echo "$line" | sed "s/ \* / Invitado_Anónimo_$anon_count /")
                    echo "$new_line"
                    ((anon_count++))
                else
                    echo "$line"
                fi
            done < /var/lib/misc/dnsmasq.leases
        else
            echo "No hi ha lloguers DHCP actius."
        fi
        echo "</div>"
        ;;
    save_config_range)
        # Arguments: interface start end
        IF=$2
        START=$3
        END=$4
        
        # Comprovar si està actiu per reiniciar després
        IS_ACTIVE=0
        if systemctl is-active --quiet dnsmasq; then IS_ACTIVE=1; fi

        CURR_LINE=$(grep "^dhcp-range=interface:$IF," /etc/dnsmasq.conf | head -n 1)
        if [ -z "$CURR_LINE" ]; then
            # Potser està comentat
            CURR_LINE=$(grep "^#dhcp-range=interface:$IF," /etc/dnsmasq.conf | head -n 1)
        fi

        if [ -n "$CURR_LINE" ]; then
            MASK=$(echo "$CURR_LINE" | cut -d',' -f4)
            LEASE=$(echo "$CURR_LINE" | cut -d',' -f5)
            
            # Conservar l'estat de comentat si ho estava
            PREFIX=""
            echo "$CURR_LINE" | grep -q "^#" && PREFIX="#"
            
            NEW_LINE="${PREFIX}dhcp-range=interface:$IF,$START,$END,$MASK,$LEASE"
            
            # Validació final al backend
            if ! is_same_subnet "$START" "$END" "$MASK"; then
                echo "ERROR: IPs must be in the same subnet ($MASK)"
                exit 1
            fi

            sed -i "s|$CURR_LINE|$NEW_LINE|" /etc/dnsmasq.conf
            echo "OK"
        else
            echo "ERROR: Interface not found"
        fi
        ;;
    toggle_range)
        # Arguments: interface
        IF=$2
        
        # Buscar la línia (activa o comentada)
        LINE=$(grep -E "^#?dhcp-range=interface:$IF," /etc/dnsmasq.conf | head -n 1)
        
        if [ -n "$LINE" ]; then
            if echo "$LINE" | grep -q "^#"; then
                # Activar: treure el #
                NEW_LINE=$(echo "$LINE" | sed 's/^#//')
            else
                # Desactivar: posar el #
                NEW_LINE="#$LINE"
            fi
            
            sed -i "s|$LINE|$NEW_LINE|" /etc/dnsmasq.conf
            echo "OK"
        else
            echo "ERROR: Interface range not found"
        fi
        ;;
    restart_if_active)
        if systemctl is-active --quiet dnsmasq; then
            systemctl restart dnsmasq > /dev/null 2>&1
            echo "RESTARTED"
        else
            echo "STAYED_OFF"
        fi
        ;;
    *)
        echo "DESACTIVAT"
        echo "<h3>Error</h3>"
        echo "<p>Ordre no reconeguda: $COMANDO</p>"
        ;;
esac
